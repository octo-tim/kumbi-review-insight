# Railway 배포용 환경변수 템플릿

# Postgres 연결 문자열
# Railway에서는 Postgres 플러그인 생성 후 앱 서비스의 Variables에서
# DATABASE_URL = ${{Postgres.DATABASE_URL}} 형태로 참조 추가하시면 자동 주입됩니다.
# 로컬 테스트용 예시:
# DATABASE_URL=postgresql://kumbi:kumbi@localhost:5432/kumbi_test

# 최초 기동 시 자동 생성되는 관리자 계정
ADMIN_EMAIL=admin@octoworks.kr
ADMIN_PASSWORD=change-this-in-production
